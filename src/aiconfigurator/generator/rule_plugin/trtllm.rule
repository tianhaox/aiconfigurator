BenchConfig.estimated_concurrency = (BenchConfig.estimated_concurrency if BenchConfig.estimated_concurrency else ((WorkerConfig.agg_workers or 0) * (params.agg.max_batch_size or 0) if DynConfig.mode == 'agg' else (WorkerConfig.decode_workers or 0) * (params.decode.max_batch_size or 0)))
agg_decode cuda_graph_batch_sizes = ((range(1, 16 + 1, 1) | list) + (range(16, 32 + 1, 4) | list) + (range(32, 64 + 1, 8) | list) + (range(64, 128 + 1, 16) | list) + (range(128, 256 + 1, 32) | list) + (range(256, 512 + 1, 64) | list) + (range((1 if (max_batch_size or 0) <= 8 else (max_batch_size or 0) - 8), (max_batch_size or 0) + 8 + 1, 1) | list))

agg_decode cuda_graph_enable_padding = true

when not (preserve_engine_limits or false):
    prefill max_batch_size = (max_batch_size if max_batch_size else 1)
    agg_decode max_batch_size = (max_batch_size if max_batch_size else 128)

prefill disable_overlap_scheduler = true
decode disable_overlap_scheduler = false
agg disable_overlap_scheduler = false

# Ensure maxNumTokens.value() % tokensPerBlock == 0 
agg_prefill_decode tokens_per_block = (tokens_per_block if tokens_per_block else 32)
when not (preserve_engine_limits or false):
    prefill max_num_tokens = (((SlaConfig.isl + 500) + tokens_per_block - 1) // tokens_per_block) * tokens_per_block
    decode max_num_tokens = ((max_batch_size + tokens_per_block - 1) // tokens_per_block) * tokens_per_block
    agg max_num_tokens = ((max_batch_size + SlaConfig.isl + 500 + tokens_per_block - 1) // tokens_per_block) * tokens_per_block
    prefill_decode cache_transceiver_max_tokens_in_buffer = (((SlaConfig.isl + SlaConfig.osl + 500) + tokens_per_block - 1) // tokens_per_block) * tokens_per_block

# Multimodal EPD encode worker (vision encoder). The SDK sweep does not size it,
# so give it small concrete batch/token budgets. Matches dynamo's qwen3-vl
# encode.yaml (max_batch_size 4, max_num_tokens 1024). Without a concrete
# max_batch_size the trtllm MultimodalEncoder gets max_num_seqs=None and crashes
# on init. Only applies when an `encode` scope exists (EPD) -> byte-safe otherwise.
encode max_batch_size = (max_batch_size if max_batch_size else 4)
encode max_num_tokens = (max_num_tokens if max_num_tokens else 1024)

# Enforce TensorRT-LLM MoE parallelism: moe_tp × moe_ep = tp
when ModelConfig.is_moe and (moe_tensor_parallel_size and moe_expert_parallel_size):
    agg_prefill_decode tensor_parallel_size = moe_tensor_parallel_size * moe_expert_parallel_size

# GPUs per worker (fallback to 1 if any dimension missing)
agg_prefill_decode gpus_per_worker = (tensor_parallel_size or 1) * (pipeline_parallel_size or 1) * (data_parallel_size or 1)

agg_prefill_decode enable_attention_dp = ((data_parallel_size or 1) > 1) and ModelConfig.is_moe

when (ModelConfig.prefix or 0) > 0:
    agg_prefill_decode disable_prefix_cache = false
    DynConfig.enable_router = true


# Speculative decoding
# Guard: in disagg, the PREFILL engine needs speculative_config too -- TRT-LLM
# sizes the KV cache with get_num_spec_layers(spec_config) extra MTP-layer
# pools, so a ctx engine without it has a mismatched KV layout vs the gen
# engine (official disaggregated benchmark config carries it on both sides).
when (ModelConfig.nextn or 0) > 0:
    agg_prefill_decode speculative_decoding_type = "MTP"
    agg_prefill_decode num_nextn_predict_layers = ModelConfig.nextn

# Guard: TRT-LLM rejects literal float16/bfloat16 as kv-cache dtype -> "auto".
when kv_cache_dtype in ("float16", "bfloat16"):
    kv_cache_dtype = "auto"
